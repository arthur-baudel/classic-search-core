# Classic AI — variables d'environnement
# Copiez ce fichier en .env et remplissez vos propres valeurs.
# Ne JAMAIS committer le fichier .env réel (voir .gitignore).

# ---------- Base vectorielle (Qdrant Cloud) ----------
QDRANT_URL=https://votre-cluster.qdrant.io
QDRANT_API_KEY=votre_cle_qdrant

# ---------- Embeddings (Voyage AI) ----------
VOYAGE_API_KEY=votre_cle_voyage

# ---------- Modèle conversationnel (Anthropic Claude) ----------
ANTHROPIC_API_KEY=votre_cle_anthropic

# ---------- Connecteur boutique (adaptez selon la plateforme utilisée) ----------
# PrestaShop
PRESTASHOP_URL=https://votre-boutique.com
PRESTASHOP_API_KEY=votre_cle_prestashop

# WooCommerce (si vous utilisez ce connecteur à la place)
# WOOCOMMERCE_URL=https://votre-boutique.com
# WOOCOMMERCE_CONSUMER_KEY=ck_xxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxx

# ---------- Sécurité API ----------
# Token partagé entre le widget et l'API (authentification simple côté client)
WIDGET_SHARED_TOKEN=generez_un_secret_aleatoire_long

# Clé d'authentification pour l'endpoint de recherche (Bearer token)
API_SECRET=generez_un_autre_secret_aleatoire

# Domaine(s) autorisé(s) en CORS, séparés par une virgule
ALLOWED_ORIGINS=https://www.votre-boutique.com,https://votre-projet.vercel.app

# ---------- Rate limiting (Upstash Redis — intégration Vercel Marketplace) ----------
# Générées automatiquement par Vercel si vous installez l'intégration Upstash.
KV_REST_API_URL=
KV_REST_API_TOKEN=
